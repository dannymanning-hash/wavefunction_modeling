       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         FractionBox["r", "a"]}]]}], 
      SqrtBox["\[Pi]"]]},
    {"2", 
     RowBox[{"2", " ", 
      SqrtBox[
       FractionBox["1", 
        SuperscriptBox["a", "3"]]], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", " ", "r"}], "a"]}]], " ", 
      SqrtBox[
       FractionBox["2", "\[Pi]"]]}]}
   },

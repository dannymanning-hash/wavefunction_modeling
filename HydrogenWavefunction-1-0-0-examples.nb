Cell["\<\
Plot the polar dependence of one wavefunction at various radii:\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.831697217418291*^9, 3.831697248142242*^9}, {
  3.831698630721344*^9, 3.831698631470435*^9}},
 CellID->5965526],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", "=", "1"}], "}"}], ",", 
   RowBox[{"PolarPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Re", "@", 
         RowBox[{
          InterpretationBox[
           TagBox[

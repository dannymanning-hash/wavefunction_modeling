}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "The", " ", "Bohr", " ", "model", " ", "predicts", " ", "that", " ", 
      "the", " ", "energy", " ", "of", " ", "a", " ", "given", " ", 
      "electron", " ", "shell", " ", "is", " ", "given", " ", "by", " ", 
      "E"}], "=", 
     RowBox[{
      RowBox[{"-", "13.6"}], "/", 
      RowBox[{"n", "^", "2"}]}]}], ",", " ", 
    RowBox[{
    "where", " ", "n", " ", "is", " ", "the", " ", "number", " ", "of", " ", 
     "the", " ", "energy", " ", 
     RowBox[{"level", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "This", " ", "function", " ", "tells", " ", "us", " ", "the", " ", 
     "energy", " ", "differential", " ", "between", " ", "two", " ", "energy",
      " ", "levels"}], ",", " ", 
    RowBox[{"n1", " ", "and", " ", 
     RowBox[{"n2", ".", " ", "A"}], " ", "positive", " ", "value", " ", 
     "indicates", " ", "that", " ", "the", " ", "electron", " ", "dropped", 
     " ", "in", " ", "energy", " ", "from", " ", "a", " ", "high", " ", 
     "level", " ", "to", " ", "a", " ", "lower", " ", "level"}], ",", " ", 
    RowBox[{
    "while", " ", "a", " ", "negative", " ", "value", " ", "indicates", " ", 
     "that", " ", "the", " ", "electron", " ", "absorbed", " ", "energy", " ",
      "to", " ", "jump", " ", "up", " ", "from", " ", "a", " ", "low", " ", 
     "level", " ", "to", " ", "a", " ", "higher", " ", 
     RowBox[{"level", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"HydrogenBohrEnergy", "[", 
     RowBox[{"n1_", ",", "n2_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", ",", "m"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n", "=", "n1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"m", "=", "n2"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "13.6"}], "/", 
         RowBox[{"n", "^", "2"}]}], "+", 
        RowBox[{"13.6", "/", 
         RowBox[{"m", "^", "2"}]}]}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"HydrogenBohrEnergy", "[", 
    RowBox[{"1", ",", "2"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9853799064771705`*^9, 3.985379907143387*^9}, {
  3.9853804340855646`*^9, 3.9853805898606205`*^9}, {3.985380637464505*^9, 
  3.9853807658973494`*^9}, {3.985381422215354*^9, 3.9853814281735973`*^9}, {
  3.985381889028185*^9, 3.9853819256517887`*^9}, {3.985381969032154*^9, 
  3.985381999548482*^9}},ExpressionUUID->"a6d50bc2-326a-431c-806b-\
6466135eeb28"],

Cell[BoxData[
 RowBox[{"-", "10.2`"}]], "Output",
 CellChangeTimes->{{3.9853807557401896`*^9, 3.9853807662923756`*^9}, 

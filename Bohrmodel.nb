Cell["\<\
The Bohr energy turned out to perfectly predict several things, most notably \
emission and absorption spectra of different elements. When certain elements \
are passed a lot of energy, they will only emit certain specific wavelengths \
of light, and when white light passes through a large cloud of a certain \
element, those same wavelengths of light get absorbed. Classical physics had \
no good explanation for this, but the Bohr model explained these absorption \
and emission lines. The wavelength of light may be calculated knowing its \
energy by the formula E=h*c/\[Lambda], where h and c are the physical \
constants and \[Lambda] is the wavelength of light.\
\>", "Text",
 CellChangeTimes->{{3.9853807939168997`*^9, 3.985380877494607*^9}, {
  3.985381106684148*^9, 3.985381131089198*^9}, {3.9853811800203905`*^9, 
  3.9853812522455144`*^9}, {3.9853812978917284`*^9, 3.985381334295385*^9}, {
  3.9853814115885305`*^9, 3.9853814678400536`*^9}, {3.985381519499286*^9, 
  3.9853815551231227`*^9}, {3.9853820845797462`*^9, 
  3.9853820946248884`*^9}},ExpressionUUID->"ec253c67-5d12-4082-884a-\
20f7c9e2a4e1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Given", " ", "the", " ", "energy", " ", "of", " ", "a", " ", "photon", 
     " ", "in", " ", "eV"}], ",", " ", 
    RowBox[{
    "this", " ", "function", " ", "returns", " ", "the", " ", "wavelength", 
     " ", "of", " ", "that", " ", "photon", " ", "in", " ", "nm"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PhotonWavelength", "[", "e_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "en", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"en", "=", "e"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Abs", "[", 
        RowBox[{"4.136", "*", 
         RowBox[{"10", "^", 
          RowBox[{"-", "15"}]}], "*", "3", "*", 
         RowBox[{
          RowBox[{"10", "^", "8"}], "/", "en"}], "*", 
         RowBox[{"10", "^", "9"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"PhotonWavelength", "[", 
    RowBox[{"HydrogenBohrEnergy", "[", 
     RowBox[{"2", ",", "3"}], "]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"PhotonWavelength", "[", 
    RowBox[{"HydrogenBohrEnergy", "[", 
     RowBox[{"2", ",", "4"}], "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.985381572793673*^9, 3.9853817995398655`*^9}, {
  3.9853818331582727`*^9, 3.9853818685433865`*^9}, {3.9853820163758965`*^9, 
  3.985382063373304*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"e1313501-49ba-426b-81b5-7c834352858a"],


Cell["\<\
The distance at which the electron is found from the nucleus at any given \
point is  the function R(r), which comes from the Schr\[ODoubleDot]dinger \
equation. Explaining and solving the Schr\[ODoubleDot]dinger equation is well \
beyond the scope of this project, but as a cursory explanation, the electron \
is more likely to be found at certain distances from the nucleus. Plotted \
below are the three simplest examples of such functions for (1, 0, 0) shown \
in blue, (2, 0, 0) shown in green, and (2, 1, 0) shown in red.\
\>", "Text",
 CellChangeTimes->{{3.9855319537992325`*^9, 3.985531980645317*^9}, {
   3.985532127607502*^9, 3.985532231656191*^9}, {3.9855405252146225`*^9, 
   3.9855405349311543`*^9}, 3.9855406112992783`*^9, {3.9855406920945225`*^9, 
   3.9855407124067917`*^9}, {3.985540822507881*^9, 3.9855408876592007`*^9}, {
   3.985541908653549*^9, 
   3.985541923423443*^9}},ExpressionUUID->"b0d11751-5214-f343-a012-\
70adf3c29123"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a0", "=", ".529"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R100", "[", "r_", "]"}], ":=", 
  RowBox[{
   RowBox[{"2", "/", 
    RowBox[{"a0", "^", 
     RowBox[{"(", 
      RowBox[{"3", "/", "2"}], ")"}]}]}], "*", 
   RowBox[{"E", "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "r"}], "/", "a0"}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R200", "[", "r_", "]"}], ":=", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", "*", "a0"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"3", "/", "2"}], ")"}]}]}], "*", 
   RowBox[{"(", 
    RowBox[{"2", "-", 
     RowBox[{"r", "/", "a0"}]}], ")"}], "*", 
   RowBox[{"E", "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "r"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "a0"}], ")"}]}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R210", "[", "r_", "]"}], ":=", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sqrt", "[", "3", "]"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "*", "a0"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"3", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"r", "/", "a0"}], "*", 
   RowBox[{"E", "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "r"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "a0"}], ")"}]}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"R100", "[", "r", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", "\"\<R(r)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", ".3"}], ",", ".8"}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"R200", "[", "r", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", "\"\<R(r)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Green"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"R210", "[", "r", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", "\"\<R(r)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}]}], "]"}]}], "]"}]}], "Input",

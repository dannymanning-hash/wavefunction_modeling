Cell[CellGroupData[{

Cell["Quantum Numbers", "Section",
 CellChangeTimes->{{3.9855157267969246`*^9, 
  3.985515729970104*^9}},ExpressionUUID->"13d53fc1-f63d-9843-814a-\
8b813f28cfbd"],

Cell[CellGroupData[{

Cell["Angular Momentum in Quantum Mechanics", "Subsection",
 CellChangeTimes->{{3.9855157331806335`*^9, 3.985515734883486*^9}, {
  3.9855157856649475`*^9, 
  3.9855157919942894`*^9}},ExpressionUUID->"fb659d06-db2a-b544-bd69-\
abb60055d23e"],

Cell[TextData[{
 "In Uncertainty.nb, we explored the idea that an electron\[CloseCurlyQuote]s \
position and momentum cannot be precisely known simultaneously. This \
disproves the Bohr model assumption that electrons orbit at fixed radii from \
the nucleus, but then that begs the question, where do electrons orbit? How \
can we describe the orbit of an electron, given the constraints of \
uncertainty?\n\nTo do so, we\[CloseCurlyQuote]ll need to add some additional \
known quantities to the energy level ",
 StyleBox["n;",
  FontSlant->"Italic"],
 " most notably, the angular momentum of an electron. Quantum angular \
momentum is weird, since it depends on both the radius and the momentum, and \
those are subject to uncertainty relations. The component of angular momentum \
is not well defined--instead, we have to specify a total magnitude and a \
component along a given direction. We use two additional quantum numbers to \
specify angular momentum: ",
 StyleBox["l ",
  FontSlant->"Italic"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "230c0f4d-192b-184d-a3e4-c4b1774ec737"],
 ".\n\n",
 StyleBox["l",
  FontSlant->"Italic"],
 " is the angular momentum quantum number, which sets the magnitude of the \
angular momentum. ",
 StyleBox["l",
  FontSlant->"Italic"],
 " is nonnegative and has to be less than ",
 StyleBox["n",
  FontSlant->"Italic"],
 ". The magnitude of L, the angular momentum, is given by L=(",
 StyleBox["l",
  FontSlant->"Italic"],
 "*(",
 StyleBox["l",
  FontSlant->"Italic"],
 "+1))^1/2.\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b641b32-8771-b14c-9c3a-2e12dae0bfe9"],
 " is the magnetic quantum number, which sets the component along the z \
direction. The rule for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5847eec7-8998-9642-beb0-c8e13cc053cd"],
 " is that |",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6bb7ecc9-aabc-554d-84e8-29b534a4a27c"],
 "|<",
 StyleBox["l.\n\n",
  FontSlant->"Italic"],
 "A valid set of quantum numbers would be ",
 StyleBox["n",
  FontSlant->"Italic"],
 "=3, ",
 StyleBox["l",
  FontSlant->"Italic"],
 "=1, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d2ba06a8-8e24-084e-a0b0-edb1131f5732"],
 "=-1. These three are typically expressed in a set, like (3, 1, -1). The \
following graphs show the basic idea of ",
 StyleBox["l ",
  FontSlant->"Italic"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c00d375e-a5b6-334d-92e8-80bac71d5fb6"],
 ", for ",
 StyleBox["l",
  FontSlant->"Italic"],
 "=2 and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "l"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1e014194-c6d2-4049-acf0-ff52323568b7"],
 "=-1, 0, and 1."
}], "Text",
 CellChangeTimes->{{3.98551581125457*^9, 3.985515885956646*^9}, {
  3.9855159426218643`*^9, 3.9855160219864616`*^9}, {3.9855160540620823`*^9, 
  3.985516278595207*^9}, {3.9855163116057053`*^9, 3.985516386881922*^9}, {
  3.9855164315688763`*^9, 3.9855165055718822`*^9}, {3.9855165925822067`*^9, 
  3.9855166778007774`*^9}, {3.9855168399760437`*^9, 3.9855169176063614`*^9}, {
  3.9855169948442764`*^9, 3.985517104215658*^9}, {3.985518338991375*^9, 
  3.9855183554932995`*^9}, {3.985531902757511*^9, 
  3.985531915533636*^9}},ExpressionUUID->"5c8471fb-f022-a948-97e0-\
6f7bac8d344b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AngularMomentum2DPlot", "[", 
   RowBox[{"l_", ",", "ml_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "ml", "]"}], ">", "l"}], ",", "False", ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"L", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"l", "*", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"Arrow", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{"L", "^", "2"}], "-", 
                RowBox[{"ml", "^", "2"}]}], "]"}], ",", "ml"}], "}"}]}], 
           "}"}], "]"}], ",", 
         RowBox[{"Axes", "->", "True"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"AngularMomentum2DPlot", "[", 
    RowBox[{"2", ",", 
     RowBox[{"-", "1"}]}], "]"}], ",", 
   RowBox[{"AngularMomentum2DPlot", "[", 
    RowBox[{"2", ",", "1"}], "]"}], ",", " ", 
   RowBox[{"AngularMomentum2DPlot", "[", 
    RowBox[{"2", ",", "0"}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9855171545685406`*^9, 3.985517154749672*^9}, {
  3.9855171979914074`*^9, 3.9855172469697704`*^9}, {3.985517317857338*^9, 
  3.9855173223221283`*^9}, {3.9855173735846825`*^9, 3.985517426129154*^9}, {
  3.9855175231363735`*^9, 3.985517629499893*^9}, {3.985517673497095*^9, 
  3.985517682295721*^9}, {3.9855177239506645`*^9, 3.9855178032603245`*^9}, {
  3.985517886536421*^9, 3.985517920332163*^9}, {3.985518319744667*^9, 
  3.985518332838154*^9}},
 CellLabel->"In[50]:=",ExpressionUUID->"c9e2cddb-1e65-4045-b403-d564bc1f38ae"],

Cell[BoxData[
 GraphicsBox[{
   ArrowBox[NCache[{{0, 0}, {5^Rational[1, 2], -1}}, {{0, 0}, {
      2.23606797749979, -1}}]], 
   ArrowBox[NCache[{{0, 0}, {5^Rational[1, 2], 1}}, {{0, 0}, {
      2.23606797749979, 1}}]], 
   ArrowBox[NCache[{{0, 0}, {6^Rational[1, 2], 0}}, {{0, 0}, {
      2.449489742783178, 0}}]]},
  Axes->True]], "Output",
 CellChangeTimes->{
  3.9855176257883377`*^9, {3.985517673932783*^9, 3.985517682786991*^9}, 
   3.985517728367449*^9, {3.985517786875288*^9, 3.9855178036673584`*^9}, {
   3.9855179034221783`*^9, 3.9855179213799877`*^9}, 3.985518333671961*^9},
 CellLabel->"Out[51]=",ExpressionUUID->"f9878a73-6f84-824a-a810-1e7c116d0a7a"]
}, Open  ]],

Cell["\<\
These plots are 2D, and thus are a little misleading. In reality, the \
electron could be anywhere on the cone formed by rotating the arrow around \
the z axis (the y-axis of a 2D plot). The following graphic shows an example \
of the full angular momentum arc.\
\>", "Text",
 CellChangeTimes->{{3.9855180132407475`*^9, 3.9855180604591255`*^9}, {
  3.985518095227421*^9, 3.9855181630788555`*^9}, {3.98553230226396*^9, 
  3.985532327570383*^9}},ExpressionUUID->"81cb9268-52e0-6444-b14a-\
e3d1e80f1fd2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AngularMomentum3DPlot", "[", 
   RowBox[{"l_", ",", "ml_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"L", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"l", "*", 
        RowBox[{"(", 
         RowBox[{"l", "+", "1"}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Plot3D", "[", 
      RowBox[{
       RowBox[{"ml", "*", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "l"}], ",", "l"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", 
         RowBox[{"-", "l"}], ",", "l"}], "}"}], ",", 
       RowBox[{"RegionFunction", "->", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "^", "2"}], "+", 
            RowBox[{"y", "^", "2"}]}], "\[LessEqual]", "L"}]}], "]"}]}]}], 
      "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"AngularMomentum3DPlot", "[", 
  RowBox[{"1", ",", "1"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9855187813667774`*^9, 3.985518836679989*^9}, {
  3.9855189568431187`*^9, 3.9855189863354073`*^9}, {3.9855190856655083`*^9, 
  3.985519156490982*^9}, {3.985519198050802*^9, 3.985519225676504*^9}, {
  3.985519300039501*^9, 3.985519308259392*^9}, {3.98553179842346*^9, 
  3.9855318006477985`*^9}, {3.9855318321378975`*^9, 3.9855318755027065`*^9}, {
  3.985532280485195*^9, 3.9855322882166233`*^9}, {3.985534963691576*^9, 
  3.9855349693720627`*^9}, {3.9855350589098682`*^9, 3.9855350614589863`*^9}, {
  3.9855423370546665`*^9, 3.985542344095085*^9}, {3.9855424450190144`*^9, 
  3.9855425104409943`*^9}},
 CellLabel->

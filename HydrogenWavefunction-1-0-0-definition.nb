Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HydrogenWavefunction", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"n_Integer", "?", "Positive"}], ",", 
       RowBox[{"l_Integer", "?", "NonNegative"}], ",", "m_Integer"}], "}"}], 
     ",", "a_", ",", 
     RowBox[{"{", 
      RowBox[{"r_", ",", "\[Theta]_", ",", "\[Phi]_"}], "}"}], ",", 
     RowBox[{"Z_Integer", ":", "1"}]}], "]"}], "/;", 
   RowBox[{
    RowBox[{"Abs", "[", "m", "]"}], "\[LessEqual]", "l", "<", "n"}]}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Rho]", "=", 
      FractionBox[
       RowBox[{"2", "Z", " ", "r"}], 
       RowBox[{"n", " ", "a"}]]}], "}"}], ",", 
    RowBox[{
     SqrtBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"2", "Z"}], 
          RowBox[{"n", " ", "a"}]], ")"}], "3"], 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "l", "-", "1"}], ")"}], "!"}], 
        RowBox[{"2", "n", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", "+", "l"}], ")"}], "!"}]}]]}]], 
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       FractionBox["\[Rho]", "2"]}], "]"}], 
     SuperscriptBox["\[Rho]", "l"], 
     RowBox[{"LaguerreL", "[", 
      RowBox[{
       RowBox[{"n", "-", "l", "-", "1"}], ",", 
       RowBox[{
        RowBox[{"2", "l"}], "+", "1"}], ",", "\[Rho]"}], "]"}], 
     RowBox[{"SphericalHarmonicY", "[", 
      RowBox[{"l", ",", "m", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}], 
   "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{3.832089371424816*^9},
 CellTags->"DefaultContent",
 CellID->412909640,ExpressionUUID->"bbb00785-d56f-4314-a932-4a7b68ee7a7e"]
}, Open  ]],


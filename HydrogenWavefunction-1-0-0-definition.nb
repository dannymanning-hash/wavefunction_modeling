  StyleBox["r", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ce9acaf6-cfcf-4f0b-bb38-7fa40ae7dd6e"],
 ", ",
 Cell[BoxData[
  StyleBox["\[Theta]", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b035c4e1-ef67-46f7-a832-eb63220a1285"],
 " and ",
 Cell[BoxData[
  StyleBox["\[Phi]", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "51ef1ac7-c3e4-4a1f-947e-4048c493fa2d"],
 "."
}], "UsageDescription",
 CellID->21335511,ExpressionUUID->"731186f2-4961-49a2-b3c9-b97491de1578"]
}, Open  ]],


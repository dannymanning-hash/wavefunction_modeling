Cell[TextData[{
 "Verify that ",
 Cell[BoxData["HydrogenWavefunction"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6b268c4a-cc3e-4116-ae4a-64d99b453947"],
 " satisfies the time-independent Schr\[ODoubleDot]dinger equation:"
}], "Text",
 TaggingRules->{},
 CellID->34170830,ExpressionUUID->"e5d12730-a5cc-4701-a4b5-3d3dc73a4754"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", "3"}], ",", 
     RowBox[{"l", "=", "2"}], ",", 
     RowBox[{"m", "=", 
      RowBox[{"-", "1"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Psi]", "=", 
     RowBox[{"HydrogenWavefunction", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", ",", "l", ",", "m"}], "}"}], ",", "a", ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}]}], "]"}]}], ";", 
    
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           SuperscriptBox["\[HBar]", "2"], 
           RowBox[{"2", "\[Mu]"}]]}], 
         RowBox[{"Laplacian", "[", 
          RowBox[{"\[Psi]", ",", 
           RowBox[{"{", 
            RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}], ",", 
           "\"\<Spherical\>\""}], "]"}]}], "-", 
        RowBox[{
         FractionBox[
          SuperscriptBox["\[ScriptE]", "2"], 
          RowBox[{"4", "\[Pi]", " ", 
           SubscriptBox["\[CurlyEpsilon]", "0"], " ", "r"}]], "\[Psi]"}]}], 
       "\[Equal]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox["\[HBar]", "2"], 
          RowBox[{"2", "\[Mu]", " ", 
           SuperscriptBox["a", "2"], 
           SuperscriptBox["n", "2"]}]]}], "\[Psi]"}]}], "/.", 
      RowBox[{"a", "\[Rule]", 
       FractionBox[
        RowBox[{"4", "\[Pi]", " ", 
         SubscriptBox["\[CurlyEpsilon]", "0"], " ", 
         SuperscriptBox["\[HBar]", "2"]}], 
        RowBox[{"\[Mu]", " ", 
         SuperscriptBox["\[ScriptE]", "2"]}]]}]}], "]"}]}]}], "]"}]], "Input",
 
 TaggingRules->{},
 CellChangeTimes->{{3.832089692173813*^9, 3.832089699173396*^9}},
 CellID->437172358,ExpressionUUID->"71ed5d10-6e64-4b06-a2ea-08c62a87fdd1"],


Cell["\<\
The squared magnitude of the wavefunction gives the probability distribution \
for finding the electron:\
\>", "Text",
 TaggingRules->{},
 CellID->547012848,ExpressionUUID->"09a972f4-d304-4ef6-a3b9-612345a73180"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"Abs", "[", 
     RowBox[{"HydrogenWavefunction", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"3", ",", "1", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", "a", ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}]}], "]"}], "]"}], 
    "2"], ",", 
   RowBox[{
    RowBox[{"a", ">", "0"}], "&&", 
    RowBox[{"r", ">", "0"}], "&&", 
    RowBox[{"0", "<", "\[Phi]", "<", "\[Pi]"}], "&&", 
    RowBox[{"0", "<", "\[Theta]", "<", 
     RowBox[{"2", "\[Pi]"}]}]}]}], "]"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.832089478438548*^9, 3.832089488695238*^9}},
 CellID->81882539,ExpressionUUID->"33d36912-e5a6-4801-b90d-4128a0e8f193"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", "r"}], 
      RowBox[{"3", " ", "a"}]]}]], " ", 
   SuperscriptBox["r", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "6"}], " ", "a"}], "+", "r"}], ")"}], "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], 
  RowBox[{"6561", " ", 
   SuperscriptBox["a", "7"], " ", "\[Pi]"}]]], "Output",
 TaggingRules->{},
 CellChangeTimes->{3.832089721902347*^9},
 CellID->215792452,ExpressionUUID->"fc4df3f3-3823-4d79-9bc9-f7251847d10e"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


Cell[BoxData[
 FractionBox[
  RowBox[{
   SqrtBox[
    FractionBox["1", 
     SuperscriptBox["a", "3"]]], " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox["r", "a"]}]]}], 
  SqrtBox["\[Pi]"]]], "Output",
 TaggingRules->{},
 CellChangeTimes->{3.8320897217804174`*^9},
 CellID->351757702,ExpressionUUID->"f48e24f5-9383-4207-8265-617648bb8926"]

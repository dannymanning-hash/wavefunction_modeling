Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", "=", "1"}], "}"}], ",", 
   RowBox[{"PolarPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Re", "@", 
         RowBox[{"HydrogenWavefunction", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"3", ",", "2", ",", "0"}], "}"}], ",", "a", ",", 
           RowBox[{"{", 
            RowBox[{"r", ",", "\[Theta]", ",", "0"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"List", 
         StyleBox[
         "\"PolarPlot options\"", "IconizedCustomName", StripOnInput -> 
          False], 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["List", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["3", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["504", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      {AspectRatio -> GoldenRatio^(-1), Axes -> False, 
       PlotLegends -> {"r = 1", "r = 2", "r = 3", "r = 4"}},
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], "]"}]], "Input",

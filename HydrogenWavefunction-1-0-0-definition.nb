Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", "=", "1"}], "}"}], ",", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"DensityPlot", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"Abs", "[", 
         RowBox[{"HydrogenWavefunction", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"3", ",", "l", ",", "0"}], "}"}], ",", "a", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              SuperscriptBox["x", "2"], "+", 
              SuperscriptBox["y", "2"]}], ",", 
             RowBox[{"ArcTan", "[", 
              RowBox[{"x", ",", "y"}], "]"}], ",", "0"}], "}"}]}], "]"}], 
         "]"}], "2"], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
       RowBox[{"{", 

 TaggingRules->{},
 CellID->509411580,ExpressionUUID->"ebdf13fe-49a6-4ae9-88a8-52c72eaa840f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a0", "=", 
      RowBox[{
       RowBox[{"Quantity", "[", "\"\<BohrRadius\>\"", "]"}], "/", 
       RowBox[{"Quantity", "[", "\"\<Meters\>\"", "]"}]}]}], ",", 
     RowBox[{"n", "=", "2"}], ",", 
     RowBox[{"l", "=", "1"}], ",", 
     RowBox[{"m", "=", "0"}]}], "}"}], ",", 
   RowBox[{"DensityPlot3D", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Abs", "[", 
       RowBox[{"HydrogenWavefunction", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"n", ",", "l", ",", "m"}], "}"}], ",", "a0", ",", 
         RowBox[{"{", 
          RowBox[{
           SqrtBox[
            RowBox[{
             SuperscriptBox["x", "2"], "+", 
             SuperscriptBox["y", "2"], "+", 
             SuperscriptBox["z", "2"]}]], ",", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"z", ",", 
             SqrtBox[
              RowBox[{
               SuperscriptBox["x", "2"], "+", 
               SuperscriptBox["y", "2"]}]]}], "]"}], ",", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}], "]"}], "]"}], "2"], 
     ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "5"}], " ", "a0"}], ",", 
       RowBox[{"5", " ", "a0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{
        RowBox[{"-", "5"}], " ", "a0"}], ",", 
       RowBox[{"5", " ", "a0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{
        RowBox[{"-", "5"}], " ", "a0"}], ",", 
       RowBox[{"5", " ", "a0"}]}], "}"}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", "Automatic"}]}], "]"}]}], 
  "]"}]], "Input",
 TaggingRules->{},

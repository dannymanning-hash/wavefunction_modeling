Cell[BoxData[{
 RowBox[{
  RowBox[{"psi", "=", 
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{"2", "*", "Pi", "*", "x"}], "]"}], "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"3", "*", "Pi", "*", "y"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DensityPlot", "[", 
   RowBox[{
    RowBox[{"psi", "^", "2"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"ColorFunction", "->", 
     RowBox[{"Function", "[", 
      RowBox[{"z", ",", 
       RowBox[{"Blend", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Black", ",", "White"}], "}"}], ",", "z"}], "]"}]}], 
      "]"}]}]}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psi", "=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      RowBox[{"x", "^", "2"}]}], "]"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"10", "*", "I", "*", "x"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Abs", "[", "psi", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
   RowBox[{"PlotPoints", "->", "300"}], ",", 
   RowBox[{"Filling", "->", "Axis"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"Function", "[", 
     RowBox[{"x", ",", 
      RowBox[{"Hue", "[", 
       RowBox[{
        RowBox[{"Arg", "[", "psi", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "Pi"}], ")"}]}], "]"}]}], "]"}]}], ",", 
   RowBox[{"ColorFunctionScaling", "->", "False"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"DensityPlot", "[", 
  RowBox[{"psi", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"PlotPoints", "->", "100"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"Function", "[", 
     RowBox[{"z", ",", 
      RowBox[{"Blend", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Cyan", ",", "Black", ",", "Red"}], "}"}], ",", "z"}], 
       "]"}]}], "]"}]}]}], "]"}]}], "Input",
